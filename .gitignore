# Terraform state files (contain sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform directory (providers and modules cache)
.terraform/

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo